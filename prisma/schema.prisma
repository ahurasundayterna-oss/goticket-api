generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Park {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  location  String?
  status    String    @default("ACTIVE")
  branches  Branch[]
}

model Branch {
  id                    String    @id @default(cuid())
  name                  String
  parkId                String
  monnifySubAccountCode String?
  suspended             Boolean   @default(false)
  createdAt             DateTime  @default(now())
  bookings              Booking[]
  park                  Park      @relation(fields: [parkId], references: [id])
  routes                Route[]
  trips                 Trip[]
  users                 User[]
}

model User {
  id               String                 @id @default(uuid())
  name             String
  email            String                 @unique
  password         String
  role             String                 @default("BRANCH_ADMIN")
  branchId         String?
  createdAt        DateTime               @default(now())
  suspended        Boolean                @default(false)
  bookingsCreated  Booking[]
  routeAssignments RouteStaffAssignment[]
  seatLocks        SeatLock[]
  Trip             Trip[]
  branch           Branch?                @relation(fields: [branchId], references: [id])
}

model Route {
  id               String                 @id @default(uuid())
  origin           String
  destination      String
  price            Float
  branchId         String
  createdAt        DateTime               @default(now())
  active           Boolean                @default(true)
  branch           Branch                 @relation(fields: [branchId], references: [id])
  staffAssignments RouteStaffAssignment[]
  trips            Trip[]

  @@unique([branchId, origin, destination])
}

model Trip {
  id            String     @id @default(cuid())
  departureCity String
  destination   String
  departureTime DateTime?
  price         Float
  totalSeats    Int
  branchId      String
  createdAt     DateTime   @default(now())
  routeId       String
  createdById   String
  fillThreshold Int?
  status        String     @default("OPEN")
  tripType      String     @default("SCHEDULED")
  seatsBooked   Int        @default(0)
  bookings      Booking[]
  seatLocks     SeatLock[]
  branch        Branch     @relation(fields: [branchId], references: [id])
  createdBy     User       @relation(fields: [createdById], references: [id])
  route         Route      @relation(fields: [routeId], references: [id])
}

model Booking {
  id               String    @id @default(cuid())
  passengerName    String
  passengerPhone   String
  seatNumber       Int
  reference        String    @unique
  bookingSource    String    @default("MANUAL")
  tripId           String
  branchId         String
  createdAt        DateTime  @default(now())
  createdById      String?
  accountNumber    String?
  bankName         String?
  paidAt           DateTime?
  paymentReference String?
  paymentStatus    String?
  totalAmount      Float?
  paymentMethod String? // "CASH" | "TRANSFER" | "ONLINE"
  nextOfKinName    String?
  nextOfKinPhone   String?
  status           String    @default("PENDING")
  branch           Branch    @relation(fields: [branchId], references: [id])
  createdBy        User?     @relation(fields: [createdById], references: [id])
  trip             Trip      @relation(fields: [tripId], references: [id])
}

model SeatLock {
  id         String   @id @default(uuid())
  tripId     String
  seatNumber Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lockedById String?
  lockedBy   User?    @relation(fields: [lockedById], references: [id])
  trip       Trip     @relation(fields: [tripId], references: [id])
}

model RouteStaffAssignment {
  id        String   @id @default(uuid())
  routeId   String
  staffId   String
  createdAt DateTime @default(now())
  route     Route    @relation(fields: [routeId], references: [id])
  staff     User     @relation(fields: [staffId], references: [id])

  @@unique([routeId, staffId])
}
